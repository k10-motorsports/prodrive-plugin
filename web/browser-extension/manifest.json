{
  "manifest_version": 3,
  "name": "RaceCor iRacing Sync",
  "version": "0.1.0",
  "description": "Scrapes your iRacing stats (rating history, race results) and syncs them to your RaceCor Pro Drive dashboard.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://members-ng.iracing.com/*",
    "https://prodrive.racecor.io/*",
    "http://localhost:3000/*",
    "http://dev.prodrive.racecor.io:3000/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://members-ng.iracing.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
