# K10 Pro Drive — Environment Variables
# Copy this file to .env.local and fill in the values

# ─── Required ───────────────────────────────────────────────────

# YouTube Data API v3 (for video embeds + playlists)
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key

# NextAuth configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-random-string

# Production: https://prodrive.racecor.io
# Development: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Discord OAuth ──────────────────────────────────────────────

# Register at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Discord OAuth2 callback URL (register in Discord app settings):
# https://prodrive.racecor.io/api/auth/callback/discord

# ─── Strapi CMS (optional) ──────────────────────────────────────

# Local development: http://localhost:1337
# Production: https://your-strapi-instance.com
STRAPI_URL=http://localhost:1337

# Create in Strapi: Settings → API Tokens → Create new API Token
STRAPI_API_TOKEN=your-strapi-api-token
