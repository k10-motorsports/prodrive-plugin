<UserControl x:Class="K10MediaBroadcaster.Plugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             Background="#1a1a1a" Foreground="White" FontFamily="Segoe UI">

    <StackPanel Margin="20">

        <!-- Header -->
        <TextBlock Text="K10 Media Broadcaster" FontSize="22" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,4"/>
        <TextBlock Text="Real-time commentary prompts for sim racing streams."
                   FontSize="12" Foreground="#999" Margin="0,0,0,24"/>

        <!-- Display Duration -->
        <TextBlock Text="PROMPT DISPLAY DURATION" FontSize="11" FontWeight="Bold"
                   Foreground="#888" Margin="0,0,0,6"/>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="DisplaySlider" Grid.Column="0"
                    Minimum="5" Maximum="120" TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    ValueChanged="DisplaySlider_ValueChanged"
                    VerticalAlignment="Center"/>
            <TextBlock x:Name="DisplayLabel" Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Foreground="White" FontSize="14" Text="30 s"/>
        </Grid>

        <!-- Show Topic Title toggle -->
        <CheckBox x:Name="ShowTitleCheck" Content="Show topic title above prompt"
                  Foreground="White" FontSize="13" Margin="0,0,0,8"
                  Checked="ShowTitleCheck_Changed" Unchecked="ShowTitleCheck_Changed"/>

        <!-- Event-Only Mode toggle -->
        <CheckBox x:Name="EventOnlyCheck" Content="Event-only mode (concise event exposition for on-air use)"
                  Foreground="White" FontSize="13" Margin="0,0,0,4"
                  Checked="EventOnlyCheck_Changed" Unchecked="EventOnlyCheck_Changed"/>
        <TextBlock Text="Shows a short, repeatable description of the event and its data value instead of full commentary prompts."
                   FontSize="10" Foreground="#666" TextWrapping="Wrap" Margin="18,0,0,20"/>

        <!-- Category toggles -->
        <TextBlock Text="ENABLED CATEGORIES" FontSize="11" FontWeight="Bold"
                   Foreground="#888" Margin="0,0,0,10"/>
        <CheckBox x:Name="CatHardware"  Content="Hardware &amp; setup"
                  Foreground="White" FontSize="13" Margin="0,0,0,6"
                  Checked="Category_Changed" Unchecked="Category_Changed"/>
        <CheckBox x:Name="CatGameFeel" Content="Game feel &amp; visuals"
                  Foreground="White" FontSize="13" Margin="0,0,0,6"
                  Checked="Category_Changed" Unchecked="Category_Changed"/>
        <CheckBox x:Name="CatCarResponse" Content="Car response &amp; physics"
                  Foreground="White" FontSize="13" Margin="0,0,0,6"
                  Checked="Category_Changed" Unchecked="Category_Changed"/>
        <CheckBox x:Name="CatRacingExp" Content="Racing experience &amp; incidents"
                  Foreground="White" FontSize="13" Margin="0,0,0,20"
                  Checked="Category_Changed" Unchecked="Category_Changed"/>

        <!-- Topics file path -->
        <TextBlock Text="TOPICS FILE PATH (optional override)" FontSize="11"
                   FontWeight="Bold" Foreground="#888" Margin="0,0,0,6"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TopicsPathBox" Grid.Column="0"
                     Background="#2a2a2a" Foreground="White" BorderBrush="#444"
                     Padding="6,4" FontSize="12"
                     TextChanged="TopicsPathBox_TextChanged"/>
            <Button Grid.Column="1" Content="Browse" Margin="6,0,0,0"
                    Background="#333" Foreground="White" BorderBrush="#555"
                    Padding="4" Click="BrowseTopics_Click"/>
        </Grid>
        <TextBlock Text="Leave empty to auto-detect k10-media-broadcaster-data/commentary_topics.json"
                   FontSize="11" Foreground="#666" Margin="0,0,0,20"/>

        <!-- Demo Mode -->
        <TextBlock Text="DEMO MODE" FontSize="11" FontWeight="Bold"
                   Foreground="#888" Margin="0,0,0,6"/>
        <CheckBox x:Name="DemoModeCheck" Content="Enable demo mode"
                  Foreground="White" FontSize="13" Margin="0,0,0,4"
                  Checked="DemoModeCheck_Changed" Unchecked="DemoModeCheck_Changed"/>
        <TextBlock Text="Cycles through all event types and severity levels as a simulated race. Max 30 seconds between events. No game session required. Use this to preview dashboard colors and prompt styles."
                   FontSize="10" Foreground="#666" TextWrapping="Wrap" Margin="18,0,0,20"/>

        <!-- Telemetry Recording -->
        <TextBlock Text="TELEMETRY RECORDING" FontSize="11" FontWeight="Bold"
                   Foreground="#888" Margin="0,0,0,6"/>
        <CheckBox x:Name="RecordModeCheck" Content="Record telemetry for offline trigger testing"
                  Foreground="White" FontSize="13" Margin="0,0,0,4"
                  Checked="RecordModeCheck_Changed" Unchecked="RecordModeCheck_Changed"/>
        <TextBlock x:Name="RecordingStatusLabel"
                   Text="Recordings saved to: %ProgramData%\SimHub\PluginsData\K10MediaBroadcaster\recordings\"
                   FontSize="10" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,4"/>
        <TextBlock Text="Use ThumbsUp / ThumbsDown actions in Control Mapper to rate prompts."
                   FontSize="10" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <!-- Track Maps -->
        <TextBlock Text="TRACK MAPS" FontSize="11" FontWeight="Bold"
                   Foreground="#888" Margin="0,0,0,6"/>

        <TextBlock Text="Compiled tracks (bundled with plugin):" FontSize="11"
                   Foreground="#999" Margin="0,0,0,4"/>
        <Border Background="#222" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                MaxHeight="140">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="BundledTracksList"
                           Text="(loading…)"
                           Foreground="#aaa" FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <TextBlock Text="Local-only tracks (not yet compiled):" FontSize="11"
                   Foreground="#999" Margin="0,0,0,4"/>
        <Border Background="#2a2218" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                MaxHeight="140">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LocalTracksList"
                           Text="(loading…)"
                           Foreground="#d4a856" FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ExportTracksBtn" Grid.Column="0"
                    Content="Save local tracks to repo…"
                    Background="#333" Foreground="White" BorderBrush="#555"
                    Padding="10,4" FontSize="12"
                    Click="ExportTracks_Click"/>
            <Button x:Name="RefreshTracksBtn" Grid.Column="1"
                    Content="Refresh"
                    Background="#333" Foreground="White" BorderBrush="#555"
                    Padding="10,4" Margin="8,0,0,0" FontSize="12"
                    Click="RefreshTracks_Click"/>
        </Grid>
        <TextBlock x:Name="ExportStatusLabel"
                   Text="" FontSize="10" Foreground="#6fcf6f" Margin="0,0,0,20"/>

        <!-- Status -->
        <Border Background="#0d3d0d" CornerRadius="4" Padding="12,8">
            <TextBlock x:Name="StatusText"
                       Text="Plugin active — waiting for game session."
                       Foreground="#6fcf6f" FontSize="12" TextWrapping="Wrap"/>
        </Border>

    </StackPanel>
</UserControl>
