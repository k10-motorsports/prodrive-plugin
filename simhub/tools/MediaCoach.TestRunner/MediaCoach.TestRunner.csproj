<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <LangVersion>10</LangVersion>
    <AssemblyName>MediaCoach.TestRunner</AssemblyName>
    <RootNamespace>MediaCoach.TestRunner</RootNamespace>
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>

  <!-- Shared source files from the plugin — linked, not copied -->
  <ItemGroup>
    <Compile Include="..\..\plugin\MediaCoach.Plugin\Engine\TelemetrySnapshot.cs"
             Link="Shared\TelemetrySnapshot.cs" />
    <Compile Include="..\..\plugin\MediaCoach.Plugin\Engine\TriggerEvaluator.cs"
             Link="Shared\TriggerEvaluator.cs" />
    <Compile Include="..\..\plugin\MediaCoach.Plugin\Models\CommentaryTopic.cs"
             Link="Shared\CommentaryTopic.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
