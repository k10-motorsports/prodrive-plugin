{
  "name": "homebridge-racecor-lights",
  "version": "0.0.8",
  "description": "Homebridge plugin for the RaceCor.io sim racing platform — maps race telemetry, flags, strategy calls, and proximity warnings to HomeKit smart light colors in real-time",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "simhub",
    "racecor",
    "sim-racing",
    "iracing",
    "telemetry",
    "smart-lights",
    "race-flags"
  ],
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.6.0"
  },
  "author": "Kevin Conboy",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.11.9",
    "homebridge": "^1.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "homebridge": ">=1.6.0"
  }
}
