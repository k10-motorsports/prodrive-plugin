<UserControl x:Class="K10Motorsports.Plugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600"
             Background="#1a1a1a" Foreground="White" FontFamily="Segoe UI">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
        <StackPanel HorizontalAlignment="Center">

            <!-- Logo -->
            <Image x:Name="BrandLogo" Width="120" Height="120" Margin="0,0,0,16"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Product name -->
            <TextBlock Text="RaceCor.io Pro Drive" FontSize="22" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Broadcaster HUD for Sim Racing"
                       FontSize="12" Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Status -->
            <Border Background="#0d3d0d" CornerRadius="4" Padding="12,8" MaxWidth="400">
                <TextBlock x:Name="StatusText"
                           Text="Plugin active — waiting for game session."
                           Foreground="#6fcf6f" FontSize="12" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>

            <!-- Configuration note -->
            <TextBlock Text="Settings have moved to the dashboard overlay."
                       FontSize="11" Foreground="#666" HorizontalAlignment="Center"
                       Margin="0,16,0,4"/>
            <TextBlock Text="Press Ctrl+Shift+S in the overlay to open settings."
                       FontSize="11" Foreground="#888" HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- Track Maps (keep since this needs local file system) -->
            <TextBlock Text="TRACK MAPS" FontSize="11" FontWeight="Bold"
                       Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock x:Name="TrackMapsDirLabel"
                       Text="Folder: (resolving…)"
                       FontSize="10" Foreground="#5a9bcf" TextWrapping="Wrap"
                       HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,8"/>

            <Grid HorizontalAlignment="Center" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ExportTracksBtn" Grid.Column="0"
                        Content="Export recorded maps"
                        Background="#333" Foreground="White" BorderBrush="#555"
                        Padding="10,4" FontSize="12"
                        Click="ExportTracks_Click"/>
                <Button x:Name="OpenFolderBtn" Grid.Column="1"
                        Content="Open folder"
                        Background="#333" Foreground="White" BorderBrush="#555"
                        Padding="10,4" Margin="8,0,0,0" FontSize="12"
                        Click="OpenTrackmapsFolder_Click"/>
                <Button x:Name="RefreshTracksBtn" Grid.Column="2"
                        Content="Refresh"
                        Background="#333" Foreground="White" BorderBrush="#555"
                        Padding="10,4" Margin="8,0,0,0" FontSize="12"
                        Click="RefreshTracks_Click"/>
            </Grid>
            <TextBlock x:Name="ExportStatusLabel"
                       Text="" FontSize="10" Foreground="#6fcf6f"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Updates -->
            <Grid HorizontalAlignment="Center" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="CheckUpdateBtn" Grid.Column="0"
                        Content="Check for updates"
                        Background="#333" Foreground="White" BorderBrush="#555"
                        Padding="10,4" FontSize="12"
                        Click="CheckUpdate_Click"/>
                <Button x:Name="InstallUpdateBtn" Grid.Column="1"
                        Content="Download &amp; Install"
                        Background="#1a5a1a" Foreground="White" BorderBrush="#2a8a2a"
                        Padding="10,4" Margin="8,0,0,0" FontSize="12"
                        Visibility="Collapsed"
                        Click="InstallUpdate_Click"/>
                <TextBlock x:Name="UpdateStatusLabel" Grid.Column="2"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="#999" FontSize="11" TextWrapping="Wrap"/>
            </Grid>
            <ProgressBar x:Name="UpdateProgress"
                         Height="4" Margin="0,6,0,0"
                         Background="#333" Foreground="#5a9bcf"
                         Visibility="Collapsed"/>
            <TextBlock x:Name="UpdateVersionLabel"
                       Text="" FontSize="10" Foreground="#5a9bcf"
                       HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>

        </StackPanel>
    </Grid>
</UserControl>
