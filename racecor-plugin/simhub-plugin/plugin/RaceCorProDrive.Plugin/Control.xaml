<UserControl x:Class="RaceCorProDrive.Plugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400"
        d:DesignWidth="600"
             Background="#1a1a1a"
        Foreground="White"
        FontFamily="Segoe UI">

    <Grid VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Margin="40">
        <StackPanel HorizontalAlignment="Center">

            <!-- Logo -->
            <Image x:Name="BrandLogo"
                    Width="120"
                    Height="120"
                    Margin="0,0,0,16"
                   Source="pack://application:,,,/RaceCorProDrive;component/logo-racecor.png"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Product name -->
            <TextBlock Text="RaceCor.io Pro Drive"
                    FontSize="22"
                    FontWeight="Bold"
                       Foreground="White"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,4"/>
            <TextBlock Text="Pro Drive — Broadcast-Grade Sim Racing HUD"
                       FontSize="12"
                    Foreground="#999"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,24"/>

            <!-- Status -->
            <Border Background="#0d3d0d"
                    CornerRadius="4"
                    Padding="12,8"
                    MaxWidth="400">
                <TextBlock x:Name="StatusText"
                           Text="Plugin active — waiting for game session."
                           Foreground="#6fcf6f"
                        FontSize="12"
                        TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                        TextAlignment="Center"/>
            </Border>


            <!-- Plugin updates moved to the Windows host
                 (RaceCor Pro Drive → Settings → System → Updates),
                 the user's primary surface. We keep a static version
                 readout here so SimHub admins can verify what's
                 loaded without launching the host. -->
            <TextBlock x:Name="VersionLabel"
                       Text="Plugin version: v0.0.0"
                       FontSize="11"
                       Foreground="#888"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Updates are managed in RaceCor Pro Drive → Settings → System."
                       FontSize="11"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       FontStyle="Italic"/>

        </StackPanel>
    </Grid>
</UserControl>
